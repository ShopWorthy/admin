{
  "openapi": "3.0.3",
  "info": {
    "title": "ShopWorthy Admin API",
    "description": "Admin panel backend: session auth, stats, orders, users, inventory, file download, OpenAPI docs.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Admin app (e.g. http://localhost:8080)"
    }
  ],
  "paths": {
    "/admin/login": {
      "get": {
        "summary": "Login page (SPA shell)",
        "responses": {
          "200": {
            "description": "HTML"
          }
        }
      },
      "post": {
        "summary": "Login (JSON)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "username": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/admin/logout": {
      "post": {
        "summary": "Logout (clears session)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/api/stats": {
      "get": {
        "summary": "Dashboard stats",
        "security": [{ "sessionAuth": [] }],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": { "type": "integer" },
                    "users": { "type": "integer" },
                    "inventory_items": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/admin/api/orders": {
      "get": {
        "summary": "List orders (proxied from main API)",
        "security": [{ "sessionAuth": [] }],
        "responses": {
          "200": { "description": "List of orders" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/admin/api/orders/{order_id}/status": {
      "put": {
        "summary": "Update order status",
        "security": [{ "sessionAuth": [] }],
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/admin/api/users": {
      "get": {
        "summary": "List users",
        "security": [{ "sessionAuth": [] }],
        "responses": {
          "200": { "description": "List of users" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/admin/api/users/{user_id}": {
      "delete": {
        "summary": "Delete user",
        "security": [{ "sessionAuth": [] }],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/admin/api/inventory": {
      "get": {
        "summary": "List inventory (PostgreSQL)",
        "security": [{ "sessionAuth": [] }],
        "responses": {
          "200": { "description": "List of inventory rows" },
          "401": { "description": "Unauthorized" },
          "500": { "description": "Server error" }
        }
      }
    },
    "/admin/api-docs": {
      "get": {
        "summary": "Swagger UI HTML",
        "responses": {
          "200": { "description": "HTML" }
        }
      }
    },
    "/admin/api-docs/openapi.json": {
      "get": {
        "summary": "OpenAPI document (this spec)",
        "responses": {
          "200": { "description": "OpenAPI JSON" }
        }
      }
    },
    "/admin/files/{filename}": {
      "get": {
        "summary": "Download file from configured FILES_DIR",
        "security": [{ "sessionAuth": [] }],
        "parameters": [
          {
            "name": "filename",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Path segment(s) under FILES_DIR"
          }
        ],
        "responses": {
          "200": { "description": "File stream" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "session",
        "description": "Flask session cookie (set after POST /admin/login)"
      }
    }
  }
}
